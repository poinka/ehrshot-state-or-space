# Copy to .env and fill in values. Never commit .env.

# ClearML
CLEARML_PROJECT=EHRSHOT/State-or-Space
CLEARML_OUTPUT_URI=
CPU_QUEUE=cpu
GPU_QUEUE=gpu

# Object storage root used by ClearML StorageManager.
# Example: s3://host:port/bucket/path/to/EHRSHOT
EHRSHOT_S3_BASE=

# Local project paths
PROJECT_ROOT=.
EHRSHOT_ROOT=EHRSHOT_MEDS

# Runtime controls
POLARS_MAX_THREADS=4
REMOTE_CPU=0
REMOTE_ANALYSIS=1
